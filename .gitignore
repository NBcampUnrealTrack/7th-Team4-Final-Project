# Visual Studio 2015 user specific files
.vs/

# These project files can be generated by the engine
*.sln

# Rider
.idea/

# Visual Studio Code
.vscode/

# Compiled source files for the engine to use
Binaries/*
Intermediate/*
Plugins/**/Binaries/*
Plugins/**/Intermediate/*
Plugins/Developer/*
Saved/*

# Builds
Build/*
BuildOutput/*

# Built data for maps
*_BuiltData.uasset

# Cache files for the editor to use
DerivedDataCache/*

# Claude Code 로컬 권한 설정 (머신 의존, 절대 경로 포함). 공통 권한은 .claude/settings.json 에서 관리.
.claude/settings.local.json

# Content 하위 폴더는 ALS / Pentagram 만 추적, 나머지는 ignore.
/Content/*
!/Content/ALS/
!/Content/Pentagram/
/Content/Pentagram/Developers/

# 유료 에셋 폴더 Ignore 처리
Content/PaidAssets/